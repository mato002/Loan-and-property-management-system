APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Vite (CSS/JS): set APP_URL to the same host users type in the browser (not only localhost).
# If you use "npm run dev" and open the site from another phone/PC, either:
#   1) Run "npm run build" and delete public/hot so all devices load /build/* assets, or
#   2) Set VITE_DEV_BIND=true and VITE_DEV_HOST=YOUR_LAN_IP (e.g. 192.168.1.10) then restart "npm run dev".
# VITE_DEV_BIND=
# VITE_DEV_HOST=
# VITE_PORT=5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Loan module: SMS forwarder webhook (same JSON body style as property). Creates unposted M-Pesa payments when payer phone matches a loan client.
LOAN_SMS_INGEST_SECRET=
# Optional shortcut: if LOAN_SMS_INGEST_SECRET is left blank, Loan ingest falls back to PROPERTY_SMS_INGEST_SECRET.
# PROPERTY_SMS_INGEST_SECRET=replace-with-a-long-random-secret

# Super Admin: set true only if this install should show system-wide loan money totals on the SA dashboard.
# SUPERADMIN_SHOW_TENANT_FINANCIAL_AGGREGATES=false

# --- M-Pesa Daraja (STK + optional B2C loan disbursements) ---
# STK (pay-ins): required for tenant/landlord STK and similar flows.
# MPESA_ENV=sandbox
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
# MPESA_STK_CALLBACK_URL=https://YOUR_PUBLIC_HOST/webhooks/mpesa/stk-callback
# MPESA_STK_SHORTCODE=
# MPESA_VERIFY_SSL=true
#
# B2C (loan disbursement payouts to customer phones): required for LoanBook → Record disbursement → M-Pesa + Retry.
# Initiator + SecurityCredential come from the Safaricom developer portal (B2C API user, encrypted credential).
# Result/Timeout URLs must be HTTPS and reachable by Safaricom (use ngrok on local dev).
# MPESA_B2C_SHORTCODE=
# MPESA_B2C_INITIATOR_NAME=
# MPESA_B2C_SECURITY_CREDENTIAL=
# MPESA_B2C_RESULT_URL=https://YOUR_PUBLIC_HOST/webhooks/mpesa/b2c-result
# MPESA_B2C_TIMEOUT_URL=https://YOUR_PUBLIC_HOST/webhooks/mpesa/b2c-result

# --- Bulk SMS provider (Pradytec AI CRM) ---
# Used by dashboard Bulk SMS Balance and provider SMS sending.
# BULKSMS_API_URL=https://crm.pradytecai.com/api
# BULKSMS_CLIENT_ID=1
# BULKSMS_API_KEY=
# BULKSMS_SENDER_ID=
# BULKSMS_BALANCE_PATH=client/balance
# BULKSMS_TIMEOUT=20
# BULKSMS_VERIFY_SSL=true
# BULKSMS_BILLING_MODE=provider
# BULKSMS_DASHBOARD_BALANCE_SOURCE=provider
